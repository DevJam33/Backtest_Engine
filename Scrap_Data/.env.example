# Configuration des scraping (optionnel)
# Si vous avez besoin de clés API ou configurations spécifiques

# Rate limiting (secondes entre requêtes)
REQUEST_DELAY=0.1

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/scraper.log

# Data paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
METADATA_DIR=data/metadata

# YFinance settings
YFINANCE_THREADS=10
